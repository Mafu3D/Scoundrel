  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "In Scoundrel, whenever you enter a room you are presented with four cards:\r\n-
    DIAMONDS are weapons - their power is equal to their value. \r\n\t- If you equip
    a weapon it replaces your current one\r\n- HEARTS are potions - they heal you
    equal to your value\r\n\t- Only your FIRST potion per room will count; any others
    rest will be discarded if used.\r\n- CLUBS and SPADES are monsters - you may
    attack them with your weapon (if you have one) or your fists:\r\n\t- Weapon:
    You take damage equal to the difference of the monster's value vs your weapon's
    and defeat it\r\n\t\t  Your weapon can only attack a monster with a value LOWER
    than the previously slain monster\r\n\t- Fists: You take damage equal to the
    monster's value and defeat it\r\n\r\nYou may take cards in any order.\r\n\r\nYou
    may run from a room if it seems too dangerous, it gets placed back on the bottom
    of the deck.\r\nBut you may never run from a room twice in a row.\r\n\r\nWhen
    a room is down to its last card, or no cards, you may move into the next room.\r\nIf
    the room still has a card in it when you go into the next, the next room contains
    that card.\r\n\r\nIf your health reaches 0, you die.\r\n\r\nIf you defeat every
    monster in the deck, you win.\r\n\r\n\r\n\r\nScoundrel was originally designed
    by Zach Gage and Kurt Bieg."
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
